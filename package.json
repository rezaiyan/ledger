{
  "name": "@rezaiyan/ledger",
  "version": "0.1.8",
  "description": "Claude Code cost + session intelligence tool",
  "author": "rezaiyan",
  "license": "MIT",
  "homepage": "https://github.com/rezaiyan/ledger#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rezaiyan/ledger.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "cost",
    "usage",
    "cli",
    "dashboard"
  ],
  "type": "module",
  "files": [
    "bin/",
    "server/",
    "tui/",
    "src/",
    "commands/",
    "dist/"
  ],
  "bin": {
    "ledger": "./bin/run.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run web:dev\"",
    "server:dev": "tsx watch server/server.ts",
    "web:dev": "vite",
    "build": "tsc && vite build",
    "server:start": "node dist/server/server.js",
    "ledger": "tsx bin/ledger.ts",
    "tui": "tsx bin/ledger.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express": "^5.0.0",
    "glob": "^11.0.0",
    "tsx": "^4.19.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
